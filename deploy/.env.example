# Copy to deploy/.env on the deploy host. compose.yaml reads these.

# REQUIRED: API key clients present in X-API-Key (or ?api_key=). Generate: openssl rand -hex 32
UTILITY_API_KEY=REPLACE_ME_64HEX
UTILITY_API_KEY_NAME=prod

# Image tag to pull. "latest" = main branch; pin to sha-XXXXXXX for reproducible deploys.
IMAGE_TAG=latest

# LAN port the MCP/health surface listens on (MedelyNAS API block). MCP at /mcp is LAN-only.
HOST_PORT=41480

# Per-key rate limit (requests/min, token bucket).
RATE_LIMIT=120

# Web-fetch tool limits. Keep FETCH_ALLOW_PRIVATE=false (the SSRF guard); only flip it on an
# isolated host where reaching LAN URLs is intentional.
FETCH_MAX_BYTES=5242880
FETCH_TIMEOUT=20
FETCH_MAX_REDIRECTS=5
FETCH_ALLOW_PRIVATE=false

# Max decoded document size accepted by extract_text (bytes).
DOC_MAX_BYTES=20971520

# CORS: leave blank (this is an MCP/API service, not a browser frontend).
ALLOWED_ORIGIN=

# OpenTelemetry → OpenObserve on MedelyNAS (joined via the medelynas_telemetry network).
# Leave blank to disable. Header is "Authorization=Basic <base64 of email:password>".
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:5080/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,host.name=medelynas
